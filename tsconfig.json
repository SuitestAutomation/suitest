{
  "compilerOptions": {
    "target": "ES2019",
    "module": "node16",
    "lib": ["ES2019"],
    "types": ["jest", "node"],
    "experimentalDecorators": true,
    "preserveConstEnums": true,
    "sourceMap": false,
    "strict": true,
    "forceConsistentCasingInFileNames": false,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "jsx": "react",
    "jsxFactory": "jsx",
    "esModuleInterop": true,
    "newLine": "lf",
    "moduleResolution": "node16"
  },
  "compileOnSave": false
}
